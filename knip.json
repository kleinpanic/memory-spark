{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "index.ts",
    "tests/*.ts",
    "evaluation/*.ts",
    "scripts/*.ts"
  ],
  "project": [
    "src/**/*.ts"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "tags": [
    "-public"
  ]
}
