{
  "name": "memory-spark",
  "version": "0.3.0",
  "description": "Autonomous Spark-powered memory plugin for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit:legacy": "tsx tests/unit.ts",
    "test:integration": "tsx tests/integration.ts",
    "bench": "tsx evaluation/benchmark.ts",
    "bench:retrieval": "tsx evaluation/benchmark.ts --tier 1",
    "bench:pipeline": "tsx evaluation/benchmark.ts --tier 2",
    "index": "tsx tools/indexer.ts",
    "lint": "eslint src/ index.ts",
    "lint:fix": "eslint src/ index.ts --fix",
    "lint:all": "eslint src/ index.ts tests/ evaluation/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' 'evaluation/**/*.ts' 'index.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' 'evaluation/**/*.ts' 'index.ts'",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run knip && npm run test:coverage",
    "ci:quick": "npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.1",
    "@sinclair/typebox": "^0.34.0",
    "apache-arrow": "^18.0.0",
    "chokidar": "^4.0.0",
    "mammoth": "^1.8.0",
    "minimatch": "^10.2.4",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "knip": "^6.0.5",
    "prettier": "^3.8.1",
    "tsx": "^4.7.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "openclaw": "*"
  }
}
